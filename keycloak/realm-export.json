{
  "realm": "student-realm",
  "enabled": true,
  "sslRequired": "none",
  "registrationAllowed": false,
  "roles": {
    "realm": [
      { "name": "assistant", "description": "Can create students" },
      { "name": "admin", "description": "Can approve students" }
    ]
  },
  "clients": [
    {
      "clientId": "student-frontend",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "redirectUris": ["http://localhost:5173/*"],
      "webOrigins": ["http://localhost:5173", "+"],
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "post.logout.redirect.uris": "http://localhost:5173/*"
      }
    }
  ],
  "users": [
    {
      "username": "assistant1",
      "enabled": true,
      "firstName": "Asha",
      "lastName": "Assistant",
      "email": "assistant1@example.com",
      "emailVerified": true,
      "credentials": [
        { "type": "password", "value": "assistant1", "temporary": false }
      ],
      "realmRoles": ["assistant"]
    },
    {
      "username": "admin1",
      "enabled": true,
      "firstName": "Aman",
      "lastName": "Admin",
      "email": "admin1@example.com",
      "emailVerified": true,
      "credentials": [
        { "type": "password", "value": "admin1", "temporary": false }
      ],
      "realmRoles": ["admin"]
    }
  ]
